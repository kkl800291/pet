NODE_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=4000

# Comma-separated production frontend origins
CORS_ORIGINS=https://admin.example.com,https://app.example.com

# Reverse proxy / cookie behavior
BACKEND_TRUST_PROXY=true
BACKEND_COOKIE_SECURE=true
BACKEND_COOKIE_SAMESITE=none

# Body / upload hardening
BACKEND_BODY_LIMIT_MB=2
BACKEND_UPLOAD_MAX_FILE_SIZE_MB=5
BACKEND_UPLOAD_MAX_FILES=3
# Allowed upload mime types are restricted to common image formats in code

# Rate limiting
BACKEND_RATE_LIMIT_WINDOW_MS=60000
BACKEND_RATE_LIMIT_MAX=300
BACKEND_AUTH_RATE_LIMIT_MAX=20

# HTTP server timeouts
BACKEND_KEEP_ALIVE_TIMEOUT_MS=5000
BACKEND_HEADERS_TIMEOUT_MS=60000
